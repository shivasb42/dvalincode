{
  "name": "dvalincode",
  "version": "0.1.0",
  "description": "A local-first, provider-neutral CLI foundation for agentic coding workflows.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "dvalincode": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm test",
    "build:binaries": "bash scripts/build-binaries.sh",
    "build:binaries:darwin": "bash scripts/build-binaries.sh darwin",
    "build:binaries:linux": "bash scripts/build-binaries.sh linux",
    "server": "node dist/server/index.js",
    "server:dev": "tsx src/server/index.ts",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build"
  },
  "keywords": [
    "cli",
    "agent",
    "developer-tools",
    "typescript",
    "coding-assistant"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "fast-glob": "^3.3.3",
    "ws": "^8.18.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.5.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}

